{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hyatusliving-agentic-inbox",
	"compatibility_date": "2026-05-07",
	"main": "./workers/app.ts",
	"workers_dev": true,
	"routes": [
		{
			"pattern": "codex-inbox.hyatusliving.com",
			"custom_domain": true
		}
	],
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		// Production deploys must also define POLICY_AUD and TEAM_DOMAIN.
		// TEAM_DOMAIN may be the base Access URL or the full /cdn-cgi/access/certs URL.
		// The worker now fails closed outside local development if Access is not configured.
		"DOMAINS": "hyatusliving.com",
		// Alias domains funnel ALL of their mail (any local part) into the single
		// managed catch-all mailbox below. Nothing is forwarded or dropped.
		"ALIAS_DOMAINS": [
			"hyatusstays.com",
			"hyatus.org"
		],
		"ALIAS_DOMAIN_MAILBOX": "catch-all@hyatusliving.com",
		"EMAIL_ADDRESSES": [
			"catch-all@hyatusliving.com",
			"ai@hyatusliving.com",
			"codex@hyatusliving.com",
			"codex1@hyatusliving.com",
			"codex2@hyatusliving.com",
			"codex3@hyatusliving.com",
			"codex4@hyatusliving.com",
			"codex5@hyatusliving.com",
			"codex6@hyatusliving.com",
			"codex7@hyatusliving.com",
			"codex8@hyatusliving.com",
			"codex9@hyatusliving.com",
			"codex10@hyatusliving.com",
			"claude@hyatusliving.com",
			"autoprocess@hyatusliving.com",
			"accounts@hyatusliving.com"
		],
		"EMAIL_ADDRESS_ALIASES": {
			"codex@hyatusliving.com": "ai@hyatusliving.com",
			"codex1@hyatusliving.com": "ai@hyatusliving.com",
			"codex2@hyatusliving.com": "ai@hyatusliving.com",
			"codex3@hyatusliving.com": "ai@hyatusliving.com",
			"codex4@hyatusliving.com": "ai@hyatusliving.com",
			"codex5@hyatusliving.com": "ai@hyatusliving.com",
			"codex6@hyatusliving.com": "ai@hyatusliving.com",
			"codex7@hyatusliving.com": "ai@hyatusliving.com",
			"codex8@hyatusliving.com": "ai@hyatusliving.com",
			"codex9@hyatusliving.com": "ai@hyatusliving.com",
			"codex10@hyatusliving.com": "ai@hyatusliving.com",
			"claude@hyatusliving.com": "ai@hyatusliving.com",
			"autoprocess@hyatusliving.com": "ai@hyatusliving.com",
			"accounts@hyatusliving.com": "ai@hyatusliving.com"
		},
		"CONTENT_FORWARD_RULES": [
			{
				"name": "airbnb-review-removal",
				"mailboxId": "ai@hyatusliving.com",
				"pattern": "\\b(?:has been removed at their request|been removed at their request|has been removed upon their request|been removed upon their request|we['’]ve removed reviews from your account)\\b",
				"flags": "i",
				"forwardTo": "autoprocess@hyatusliving.com"
			},
			{
				"name": "expedia-partner-central-review-removal",
				"mailboxId": "ai@hyatusliving.com",
				"pattern": "\\b(?:Guest review removed|Customer Review Removal)\\b",
				"flags": "i",
				"forwardTo": "autoprocess@hyatusliving.com"
			},
			{
				"name": "vrbo-review-removal",
				"mailboxId": "ai@hyatusliving.com",
				"pattern": "\\b(?:review was taken down|review removed|review has been removed|taken down from VRBO)\\b",
				"flags": "i",
				"forwardTo": "autoprocess@hyatusliving.com"
			},
			{
				"name": "booking-review-removal",
				"mailboxId": "ai@hyatusliving.com",
				"pattern": "\\b(?:review removed|removed review|guest review removed|review has been removed|review was removed|customer review removal)\\b",
				"flags": "i",
				"forwardTo": "autoprocess@hyatusliving.com"
			}
		],
		"OPENAI_MODEL": "gpt-4.1-mini",
		"SIMPLE_AI_STRUCTURED_URL": "https://fast.gptpricing.com/simple-ai/structured",
		"REVIEW_REMOVAL_URL": "https://gn6slmok95.execute-api.us-east-1.amazonaws.com/dev/admin-api/review-removal",
		"AIRBNB_REVIEW_REMOVAL_URL": "https://gn6slmok95.execute-api.us-east-1.amazonaws.com/dev/admin-api/airbnb-review-removal",
		"TWOFA_POST_URL": "https://kjc0ypdntl.execute-api.us-east-1.amazonaws.com/dev/api/twofa",
		"CONTENT_LABEL_RULES": [
			{
				"name": "autoprocess-inbound",
				"mailboxId": "ai@hyatusliving.com",
				"recipientPattern": "^autoprocess@hyatusliving\\.com$",
				"pattern": "[\\s\\S]*",
				"flags": "i",
				"folderId": "autoprocess",
				"folderName": "Auto Process"
			},
			{
				"name": "keycafe",
				"mailboxId": "ai@hyatusliving.com",
				"recipientPattern": "^ai@hyatusliving\\.com$",
				"pattern": "\\bKeycafe\\b|noreply@keycafe\\.com|Important Notice:.*(?:Issue At|Is Experiencing An Issue|Has Been Resolved)",
				"flags": "i",
				"folderId": "keycafe",
				"folderName": "Keycafe"
			},
			{
				"name": "openai-chatgpt-two-fa",
				"mailboxId": "ai@hyatusliving.com",
				"fromPattern": "^(?:[^@\\s]+@(?:tm\\d*\\.)?openai\\.com|tm@openai\\.com)$",
				"recipientPattern": "\\b(?:ai|codex(?:10|[1-9])?)@hyatusliving\\.com\\b",
				"pattern": "(?=[\\s\\S]*\\bYour temporary ChatGPT (?:login|verification) code\\b)(?=[\\s\\S]*\\bEnter this temporary verification code to continue\\b)",
				"flags": "i",
				"folderId": "two-fa-dynamo",
				"folderName": "Two FA Dynamo"
			},
			{
				"name": "autohost-login-two-fa",
				"mailboxId": "ai@hyatusliving.com",
				"fromPattern": "^no-reply@notice\\.autohost\\.ai$",
				"recipientPattern": "\\bai@hyatusliving\\.com\\b",
				"pattern": "(?=[\\s\\S]*\\bYour Autohost login verification code\\b)(?=[\\s\\S]*\\bPlease verify your login attempt\\b)(?=[\\s\\S]*\\bverification code below\\b[\\s\\S]{0,1200}\\b\\d{6}\\b)",
				"flags": "i",
				"folderId": "two-fa-dynamo",
				"folderName": "Two FA Dynamo"
			},
			{
				"name": "mmt-one-time-passcode-two-fa",
				"mailboxId": "ai@hyatusliving.com",
				"fromPattern": "^noreply@go-mmt\\.com$",
				"recipientPattern": "\\bai@hyatusliving\\.com\\b",
				"pattern": "(?=[\\s\\S]*\\bOTP\\b)(?=[\\s\\S]*\\b(?:one-time passcode|use the below one-time passcode)\\b)(?=[\\s\\S]*\\b\\d{4,8}\\b)",
				"flags": "i",
				"folderId": "two-fa-dynamo",
				"folderName": "Two FA Dynamo"
			}
		],
		"INBOUND_ONLY": "true",
		"AUTO_DRAFT_ENABLED": "false",
		"SUPER_ADMIN_EMAILS": ["michaelort@hyatus.com", "fahad@hyatus.com"],
		"BOOTSTRAP_MAILBOX_GRANTS": [
			{
				"mailboxId": "ai@hyatusliving.com",
				"principalType": "service_token",
				"principalId": "687101efd9c5f56aff9fb7478c2d15da.access",
				"role": "service_agent",
				"label": "Codex agent service token"
			},
			{
				"mailboxId": "ai@hyatusliving.com",
				"principalType": "service_token",
				"principalId": "7a5c23202a8410d74904dbc159b6b1df.access",
				"role": "service_agent",
				"label": "Codex mail audit service token"
			}
		]
	},
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "hyatusliving-agentic-inbox",
			"preview_bucket_name": "hyatusliving-agentic-inbox"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "MAILBOX",
				"class_name": "MailboxDO"
			},
			{
				"name": "EMAIL_AGENT",
				"class_name": "EmailAgent"
			},
			{
				"name": "EMAIL_MCP",
				"class_name": "EmailMCP"
			},
			{
				"name": "AUTHZ",
				"class_name": "AuthzDO"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"MailboxDO"
			]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": [
				"EmailAgent"
			]
		},
		{
			"tag": "v3",
			"new_sqlite_classes": [
				"EmailMCP"
			]
		},
		{
			"tag": "v4",
			"new_sqlite_classes": [
				"AuthzDO"
			]
		}
	]
}
